{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["aipro/claude-opus-4-6", "openai/gpt-5.2"]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": ["anthropic/claude-opus-4-6", "aipro/claude-opus-4-6"]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "variant": "high",
      "fallback_models": ["anthropic/claude-opus-4-6", "aipro/claude-opus-4-6"]
    },
    "librarian": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["aipro/claude-sonnet-4-6", "aipro/gemini-3.1-pro-preview"]
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": ["aipro/gemini-3-flash"]
    },
    "multimodal-looker": {
      "model": "aipro/gemini-3-flash-preview",
      "fallback_models": ["aipro/gemini-3-flash", "aipro/gemini-2.5-pro"]
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["aipro/claude-opus-4-6", "openai/gpt-5.2"]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["aipro/claude-opus-4-6", "openai/gpt-5.2"]
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "variant": "medium",
      "fallback_models": ["anthropic/claude-opus-4-6", "aipro/claude-opus-4-6"]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["aipro/claude-sonnet-4-6", "aipro/gemini-3.1-pro-preview"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "aipro/gemini-3.1-pro-preview",
      "fallback_models": ["aipro/gemini-2.5-pro", "anthropic/claude-sonnet-4-6"]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": ["anthropic/claude-opus-4-6", "aipro/claude-opus-4-6"]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": ["anthropic/claude-opus-4-6", "aipro/claude-opus-4-6"]
    },
    "artistry": {
      "model": "aipro/gemini-3.1-pro-preview",
      "fallback_models": ["aipro/gemini-2.5-pro", "anthropic/claude-sonnet-4-6"]
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": ["aipro/gemini-3-flash"]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["aipro/claude-sonnet-4-6", "aipro/gemini-3.1-pro-preview"]
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["aipro/claude-opus-4-6", "openai/gpt-5.2"]
    },
    "writing": {
      "model": "aipro/gemini-3-flash-preview",
      "fallback_models": ["aipro/gemini-3-flash", "anthropic/claude-sonnet-4-6"]
    }
  }
}
