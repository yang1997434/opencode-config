{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "provider": {
    "aipro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIPro",
      "options": {
        "baseURL": "https://vip.aipro.love/v1",
        "apiKey": "YOUR_AIPRO_API_KEY"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (AIPro)",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (AIPro)",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "limit": {
            "context": 1048576,
            "output": 65535
          }
        },
        "gemini-3.1-pro-high": {
          "name": "Gemini 3.1 Pro High",
          "limit": {
            "context": 1048576,
            "output": 65535
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 65535
          }
        }
      }
    }
  }
}
