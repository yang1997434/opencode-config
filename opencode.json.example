{
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://codex.viloze.com/v1",
        "apiKey": "YOUR_OPENAI_RELAY_API_KEY"
      },
      "models": {
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "google": {
      "name": "Google",
      "options": {
        "baseURL": "https://code.newcli.com/gemini",
        "apiKey": "YOUR_GOOGLE_RELAY_API_KEY"
      },
      "models": {
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Relay)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
